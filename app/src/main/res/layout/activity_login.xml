<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".login.LoginActivity">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/backbutton"
                android:padding="@dimen/_5sdp"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginTop="@dimen/_20sdp"
                android:src="@drawable/ic_back_one"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"/>



            <TextView
                android:alpha="0.9"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:fontFamily="@font/poppins_semibold"
                android:paddingHorizontal="@dimen/_15sdp"
                android:text="Sign in"
                android:textColor="@color/black"
                android:textSize="@dimen/_15sdp" />

            <TextView
                android:alpha="0.5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:fontFamily="@font/poppins_semibold"
                android:paddingHorizontal="@dimen/_15sdp"
                android:text="Enter your mobile number to continue"
                android:textColor="@color/black"
                android:textSize="@dimen/_10sdp" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:layout_marginTop="@dimen/_30sdp"
                    android:paddingStart="@dimen/_10sdp"
                    android:drawablePadding="@dimen/_7sdp"
                    android:id="@+id/login_user_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_15sdp"
                    android:autofillHints="phone"
                    android:background="@drawable/box_frame_offwhite"
                    android:fontFamily="@font/poppins_semibold"
                    android:hint="@string/phone_number"
                    android:inputType="number"
                    android:maxLength="10"
                    android:paddingVertical="@dimen/_10sdp"
                    android:textAppearance="@style/customTextTheme"
                    android:textColor="@color/black"
                    android:paddingEnd="5dp"
                    android:textColorHint="@color/hintcolor"
                    android:textSize="14sp"
                    tools:ignore="RtlSymmetry" />


                <com.scottyab.showhidepasswordedittext.ShowHidePasswordEditText
                    android:id="@+id/loginUserPassword"
                    android:layout_marginHorizontal="@dimen/_15sdp"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:drawablePadding="@dimen/_7sdp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="password"
                    android:background="@drawable/box_frame_offwhite"
                    android:elevation="0dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:hint="@string/password"
                    android:inputType="text"
                    android:paddingVertical="@dimen/_10sdp"
                    android:paddingStart="@dimen/_10sdp"
                    android:paddingEnd="5dp"
                    android:textAppearance="@style/customTextTheme"
                    android:textColor="@color/black"
                    android:textColorHint="@color/hintcolor"
                    android:textSize="14sp"
                    tools:ignore="RtlSymmetry" />


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/loginForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:layout_marginTop="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center_horizontal"
                    android:text="@string/forgot_password"
                    android:textColor="@color/primarydark"
                    android:textSize="16sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/loginLoginBT"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_25sdp"
                android:layout_marginTop="24dp"
                android:background="@drawable/primary_button_design"
                android:elevation="0dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/login"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatTextView
                    android:layout_marginBottom="@dimen/_15sdp"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/loginSignUpTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="New User ? Register Now"
                    android:textColor="@color/primarydark"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-38dp"
                    android:text="@string/contact_us"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="-10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/gray"
                    android:visibility="gone" />

            </LinearLayout>


    </ScrollView>

    <ImageView
        android:padding="@dimen/_10ssp"
        android:id="@+id/whatsappnew"
        android:layout_margin="@dimen/_10ssp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_width="@dimen/_55sdp"
        android:layout_height="@dimen/_55sdp"
        android:contentDescription="@string/logo"
        android:src="@drawable/ic_whatsapp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/contactInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_margin="10dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/whatsLinear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/logo"
                    android:src="@drawable/ic_whatsapp" />

                <TextView
                    android:id="@+id/whatsAppNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="5dp"
                    android:text="@string/phone_number"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/callLinear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/logo"
                    android:src="@drawable/ic_call" />

                <TextView
                    android:id="@+id/callNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="5dp"
                    android:text="@string/phone_number"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/telegramLinear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/logo"
                    android:src="@drawable/ic_telegram" />

                <TextView
                    android:id="@+id/telegramNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="5dp"
                    android:text="@string/phone_number"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>


    </LinearLayout>


    <RelativeLayout
        android:id="@+id/progressbar2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_gravity="center"
        android:gravity="center"
        android:translationZ="10dp"
        android:visibility="gone">

        <include layout="@layout/custom_progress_bar" />
    </RelativeLayout>

</RelativeLayout>