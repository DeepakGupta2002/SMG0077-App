<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".login.ForgotPasswordActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:src="@drawable/login_top_background"
            android:layout_width="match_parent"
            android:layout_height="150dp"/>

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="30dp"
            android:layout_gravity="left"
            android:layout_height="30dp"
            android:layout_marginStart="15dp"
            android:layout_marginTop="30dp"
            android:src="@drawable/back_box_ic"
            app:tint="@color/black" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <!--           <androidx.appcompat.widget.AppCompatImageView
                           android:id="@+id/login_user_image"
                           android:layout_width="150dp"
                           android:layout_height="120dp"
                           android:layout_centerHorizontal="true"
                           android:contentDescription="@string/user_image"
                           android:elevation="5dp"
                           android:src="@drawable/logo" />-->

         <!--   <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="25dp"
                android:fontFamily="@font/roboto_medium"
                android:text="@string/app_title"
                android:textColor="@color/primary"
                android:textSize="35sp" />-->



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:layout_marginHorizontal="15dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Forgot Pin"
                android:textColor="@color/black"
                android:textSize="24dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/top_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="@string/forgot_password_full"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/ForgotPhone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="20dp"
                android:autofillHints="phone"
                android:background="@drawable/box_frame_offwhite"
                android:fontFamily="@font/roboto_medium"
                android:hint="@string/phone_number"
                android:inputType="number"
                android:maxLength="10"
                android:paddingStart="10dp"
                android:paddingEnd="5dp"
                android:textAppearance="@style/customTextTheme"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textSize="11sp"
                tools:ignore="RtlSymmetry" />

            <com.scottyab.showhidepasswordedittext.ShowHidePasswordEditText
                android:id="@+id/ForgotNewPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="20dp"
                android:autofillHints="@string/new_password"
                android:background="@drawable/box_frame_offwhite"
                android:fontFamily="@font/roboto_medium"
                android:hint="@string/new_password"
                android:inputType="textPassword"
                android:paddingStart="10dp"
                android:paddingEnd="5dp"
                android:textAppearance="@style/customTextTheme"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textSize="11sp"
                app:additionalTouchTargetSize="50dp"
                tools:ignore="RtlSymmetry" />

            <com.scottyab.showhidepasswordedittext.ShowHidePasswordEditText
                android:id="@+id/ForgotConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="20dp"
                android:autofillHints="@string/confirm_password"
                android:background="@drawable/box_frame_offwhite"
                android:drawablePadding="10dp"
                android:fontFamily="@font/roboto_medium"
                android:hint="@string/confirm_password"
                android:inputType="textPassword"
                android:paddingStart="10dp"
                android:paddingEnd="5dp"
                android:textAppearance="@style/customTextTheme"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textSize="11sp"
                app:additionalTouchTargetSize="50dp"
                tools:ignore="RtlSymmetry" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/forgotPasswordBT"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/primary_button_design"
                android:elevation="10dp"
                android:fontFamily="@font/roboto_medium"
                android:text="@string/change"
                android:textAllCaps="false"
                android:textColor="@color/back_dark"
                android:textSize="20sp"
                android:textStyle="bold" />





        </LinearLayout>

        <RelativeLayout
            android:id="@+id/progressbar2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:gravity="center"
            android:translationZ="10dp"
            android:visibility="gone">

            <include layout="@layout/custom_progress_bar" />
        </RelativeLayout>

    </RelativeLayout>


</androidx.core.widget.NestedScrollView>