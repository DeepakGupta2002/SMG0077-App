<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true"
    tools:context=".bating.BatScreenActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/layer1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/myappbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.appcompat.widget.Toolbar
                        android:id="@+id/toolbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/black"
                        android:minHeight="?attr/actionBarSize"
                        android:theme="?attr/actionBarTheme" />

                    <ImageView
                        android:id="@+id/userbackbut"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="10dp"
                        android:contentDescription="@string/back"
                        android:src="@drawable/ic_baseline_arrow_back" />

                    <TextView

                        android:layout_centerVertical="true"
                        android:layout_centerHorizontal="true"
                        android:id="@+id/bid_window_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="@string/app_name"
                        android:textColor="@color/white"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/bid_window_walletpoint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="15dp"
                        android:drawablePadding="10dp"
                        android:text="@string/rupee_symbol"
                        android:textColor="@color/back_dark"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:drawableLeftCompat="@drawable/ic_wallet"
                        app:drawableTint="@color/white" />

                </RelativeLayout>


            </com.google.android.material.appbar.AppBarLayout>

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/liner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layer1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:orientation="vertical">

                <LinearLayout
                    android:gravity="center"
                    android:id="@+id/linearLayout10"
                    android:background="@drawable/passcode_view_bg_curb"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:elevation="5dp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline4"
                    app:layout_constraintStart_toStartOf="@+id/guideline3"
                    app:layout_constraintTop_toBottomOf="@+id/textView4">
                    <TextView
                        android:textSize="16sp"
                        android:textColor="#fff"
                        android:id="@+id/bid_window_currentDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose Date"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/bid_window_choosesessionTV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/choose_session"
                    android:textColor="@color/primarydark"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="12sp" />

                <RadioGroup
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/session_group"
                    android:clipToPadding="false"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="5dp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline4"
                    app:layout_constraintStart_toStartOf="@+id/guideline3"
                    app:layout_constraintTop_toBottomOf="@+id/textView7">
                    <RadioButton
                        android:textSize="18sp"
                        android:gravity="center"
                        android:id="@+id/bid_window_opensession"
                        android:background="@drawable/add_found_bg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:checked="true"
                        android:text="Open"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:elevation="5dp"
                        android:buttonTint="@color/colorAccent"/>
                    <RadioButton
                        android:textSize="18sp"
                        android:gravity="center"
                        android:id="@+id/bid_window_closesession"
                        android:background="@drawable/add_found_bg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Close"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:elevation="5dp"
                        android:buttonTint="@color/colorAccent"/>
                </RadioGroup>

                <TextView
                    android:id="@+id/bid_window_opendigitTV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/open_digit"
                    android:textColor="@color/primarydark"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="12sp" />

                <AutoCompleteTextView
                    android:id="@+id/bid_window_opendigit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/box_frame_offwhite"
                    android:completionThreshold="1"
                    android:gravity="center_vertical"
                    android:hint="Enter Digit"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="11sp"
                    tools:ignore="RtlSymmetry" />

                <TextView
                    android:id="@+id/closepanatextview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/close_pana"
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <AutoCompleteTextView
                    android:id="@+id/bid_window_closedigit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/box_frame_offwhite"
                    android:completionThreshold="1"
                    android:gravity="center_vertical"
                    android:hint="@string/enter_point"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/primary"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:ignore="RtlSymmetry" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/points"
                    android:textColor="@color/primarydark"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/bid_window_points"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/box_frame_offwhite"
                    android:gravity="center_vertical"
                    android:hint="@string/enter_point"
                    android:inputType="number"
                    android:maxLength="6"
                    android:paddingStart="10dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="11sp"
                    tools:ignore="RtlSymmetry" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/user_proceed_Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/primary_button_design"
                    android:gravity="center"
                    android:text="@string/proceed"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/user_submit_Button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/button_design_one"
                    android:gravity="center"
                    android:text="@string/submit"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>


        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/liner"
            android:layout_margin="10dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bid_window_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/progressbar2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:background="@color/transparent"
            android:gravity="center"
            android:visibility="gone">

            <include layout="@layout/custom_progress_bar" />
        </RelativeLayout>
    </RelativeLayout>

</androidx.core.widget.NestedScrollView>