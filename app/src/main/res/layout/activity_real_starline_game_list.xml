<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_dark">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/layer1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/myappbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.appcompat.widget.Toolbar
                        android:id="@+id/toolbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/primarydark"
                        android:minHeight="?attr/actionBarSize"
                        android:theme="?attr/actionBarTheme" />

                    <ImageView
                        android:id="@+id/userbackbut"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="10dp"
                        android:src="@drawable/ic_baseline_arrow_back" />

                    <TextView
                        android:id="@+id/welcometxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/roboto_medium"
                        android:text="@string/starline_game"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />


                </RelativeLayout>


            </com.google.android.material.appbar.AppBarLayout>

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_margin="10dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <RelativeLayout
                    android:id="@+id/substarline_singledigit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="5dp"
                    android:layout_marginVertical="10dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_marginHorizontal="@dimen/_10sdp"
                        android:src="@drawable/ic_game_back"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <ImageView
                        android:id="@+id/image1"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:layout_centerHorizontal="true"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ace_ic_single_dice" />

                    <TextView
                        android:paddingTop="@dimen/_2sdp"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:background="@drawable/ic_name_back"
                        android:gravity="center_horizontal"
                        android:layout_below="@+id/image1"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_30sdp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Single Digit"
                        android:textColor="@color/white"
                        android:textSize="15sp" />



                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/substarline_singlepana"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginVertical="10dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_marginHorizontal="@dimen/_10sdp"
                        android:src="@drawable/ic_game_back"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <ImageView
                        android:id="@+id/image2"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:layout_centerHorizontal="true"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@drawable/ace_one_image" />

                    <TextView
                        android:paddingTop="@dimen/_2sdp"
                        android:gravity="center_horizontal"
                        android:background="@drawable/ic_name_back"
                        android:layout_below="@+id/image2"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_30sdp"
                        android:layout_marginTop="15dp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Single Panna"
                        android:textColor="@color/white"
                        android:textSize="15sp" />


                </RelativeLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_margin="10dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <RelativeLayout
                    android:id="@+id/substarline_doublepana"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                     android:layout_marginHorizontal="@dimen/_5sdp"
                    android:layout_marginVertical="10dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_marginHorizontal="@dimen/_10sdp"
                        android:src="@drawable/ic_game_back"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <ImageView
                        android:id="@+id/image3"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:layout_centerHorizontal="true"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@drawable/ace_two" />

                    <TextView
                        android:paddingTop="@dimen/_2sdp"
                        android:background="@drawable/ic_name_back"
                        android:gravity="center_horizontal"
                        android:layout_below="@+id/image3"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_30sdp"
                        android:layout_marginTop="15dp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Double Panna"
                        android:textColor="@color/white"
                        android:textSize="15sp" />




                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/substarline_triplepana"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="5dp"
                    android:layout_marginVertical="10dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_marginHorizontal="@dimen/_8sdp"
                        android:src="@drawable/ic_game_back"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <ImageView
                        android:id="@+id/image4"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:layout_centerHorizontal="true"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@drawable/ace_three" />

                    <TextView
                        android:gravity="center_horizontal"
                        android:paddingTop="@dimen/_2sdp"
                        android:layout_below="@+id/image4"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_30sdp"
                        android:layout_marginTop="15dp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Triple Panna"
                        android:background="@drawable/ic_name_back"
                        android:textColor="@color/white"
                        android:textSize="15sp" />



                </RelativeLayout>


            </LinearLayout>
        </LinearLayout>


    </LinearLayout>

</RelativeLayout>