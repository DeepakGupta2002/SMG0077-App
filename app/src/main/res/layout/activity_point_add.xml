<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/back_dark"
    tools:context=".transfer.PointAddActivity">

    <RelativeLayout
        android:id="@+id/layer1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/myappbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/black"
                    android:minHeight="?attr/actionBarSize"
                    android:theme="?attr/actionBarTheme" />

                <ImageView
                    android:id="@+id/userbackbut"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="10dp"
                    android:contentDescription="@string/images"
                    android:src="@drawable/ic_baseline_arrow_back" />

                <TextView
                    android:id="@+id/welcometxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:layout_marginStart="20dp"
                    android:fontFamily="@font/roboto_medium"
                    android:text="@string/add_points"
                    android:textColor="@color/white"
                    android:textSize="20sp" />

            </RelativeLayout>

        </com.google.android.material.appbar.AppBarLayout>

    </RelativeLayout>

        <LinearLayout
            android:id="@+id/layer2"
            android:layout_below="@id/layer1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/top_corner_white"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="25dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/roboto_medium"
                android:text="@string/add_points"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <EditText
                android:layout_marginTop="@dimen/_5sdp"
                android:id="@+id/addpoint_apppoints"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_40sdp"
                android:autofillHints="@string/add_points"
                android:background="@drawable/box_frame_offwhite"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center_vertical"
                android:hint="@string/add_points"
                android:inputType="number"
                android:paddingStart="15dp"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textSize="12sp"
                tools:ignore="RtlSymmetry" />

            <TextView
                android:fontFamily="@font/poppins_semibold"
                android:id="@+id/phonepe_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/black"
                android:textSize="14dp"
                android:visibility="visible" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/roboto_medium"
                android:text="@string/select_method"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textSize="16sp" />



            <LinearLayout
                android:layout_marginTop="@dimen/_5sdp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioGroup
                    android:id="@+id/addpoint_Radiogroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/addpoint_paytm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/primary"
                        android:fontFamily="@font/roboto_medium"
                        android:text="@string/paytm"
                        android:buttonTint="@color/black"
                        android:textColor="@color/black"
                        android:textSize="14sp" />

                    <RadioButton
                        android:buttonTint="@color/black"
                        android:id="@+id/addpoint_googlepay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/primary"
                        android:fontFamily="@font/roboto_medium"
                        android:text="@string/google_pay"
                        android:textColor="@color/black"
                        android:textSize="14sp" />

                    <RadioButton
                        android:buttonTint="@color/black"
                        android:id="@+id/addpoint_phonepay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/primary"
                        android:fontFamily="@font/roboto_medium"
                        android:text="@string/phonepe"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:visibility="visible" />

                    <RadioButton
                        android:buttonTint="@color/black"
                        android:id="@+id/addpoint_others"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/primary"
                        android:fontFamily="@font/roboto_medium"
                        android:text="@string/other"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:visibility="visible" />

                </RadioGroup>

                <ImageView
                    android:id="@+id/addpoint_whatappbut"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="-60dp"
                    android:layout_marginTop="30dp"
                    android:src="@drawable/ic_whatsapp_new" />

            </LinearLayout>

            <TextView
                android:id="@+id/othertext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/red"
                android:textSize="14dp"
                android:visibility="gone" />


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/user_proceed_Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/primary_button_design"
                android:fontFamily="@font/roboto_medium"
                android:text="@string/proceed"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="20sp" />

        </LinearLayout>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layer2"
        android:background="@color/back_dark">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/addpoint_swiprefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/Add_point_recyclerview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="5dp"
                    android:paddingTop="10dp" />

            </LinearLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>


    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/progressbar2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:background="@color/transparent"
        android:gravity="center"
        android:visibility="gone">

        <include layout="@layout/custom_progress_bar" />
    </RelativeLayout>


</RelativeLayout>