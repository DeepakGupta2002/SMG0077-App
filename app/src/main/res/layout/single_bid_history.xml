<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardBackgroundColor="@color/primarydark"
    app:cardCornerRadius="5dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/sing_win_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title text (Subtext)"
            android:fontFamily="@font/kohsantepheap_bold"
            android:textAllCaps="true"
            android:textColor="@color/black"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/sing_digitvalue"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="10 Points"
            android:textColor="@color/yellowColorn"
            android:fontFamily="@font/roboto_medium"
            android:textSize="11sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/sing_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:background="@drawable/box_frame_offwhite"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:text="@string/_20"
                android:textColor="@color/black"
                android:fontFamily="@font/roboto_medium"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sing_sessionstatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="@string/change"
                android:fontFamily="@font/roboto_medium"
                android:textColor="@color/sky_blue"
                android:textSize="12sp" />

        </RelativeLayout>

        <TextView
            android:id="@+id/sing_datetime"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/dummy_full_date"
            android:fontFamily="@font/roboto_medium"
            android:textColor="@color/white"
            android:textSize="11sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>