<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".login.SignUpActivity"
    android:fillViewport="true"
    android:background="@color/back_dark">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <ImageView
            android:id="@+id/backbutton"
            android:padding="@dimen/_5sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_marginTop="@dimen/_20sdp"
            android:src="@drawable/ic_back_one"
            android:layout_width="@dimen/_40sdp"
            android:layout_height="@dimen/_40sdp"/>

        <LinearLayout
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_below="@+id/backbutton"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_8sdp"
            android:layout_width="match_parent"
            android:background="@drawable/bottom_corner_white"
            android:orientation="vertical">

            <TextView
                android:layout_marginTop="@dimen/_20sdp"
                android:layout_width="match_parent"
                android:fontFamily="@font/poppins_semibold"
                android:paddingHorizontal="10dp"
                android:layout_height="wrap_content"
                android:text="REGISTER"
                android:alpha="0.9"
                android:textColor="@color/black"
                android:textSize="@dimen/_15sdp" />

            <TextView
                android:alpha="0.5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/urbanist_medium"
                android:paddingHorizontal="@dimen/_10sdp"
                android:text="Create an account to Continue"
                android:textColor="@color/black"
                android:textSize="@dimen/_11sdp" />

            <androidx.appcompat.widget.AppCompatEditText
                android:drawablePadding="@dimen/_7sdp"
                android:layout_marginTop="@dimen/_30sdp"
                android:id="@+id/SignUpUserName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:elevation="4dp"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:autofillHints="@string/user_name"
                android:background="@drawable/box_frame_offwhite"
                android:fontFamily="@font/poppins_semibold"
                android:hint="@string/user_name"
                android:inputType="textCapSentences"
                android:paddingStart="10dp"
                android:imeOptions="actionNext"
                android:paddingEnd="5dp"
                android:textAppearance="@style/customTextTheme"
                android:textColor="@color/black"
                android:textColorHint="@color/hintcolor"
                android:textSize="15sp"
                tools:ignore="RtlSymmetry" />

            <TextView
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:paddingHorizontal="@dimen/_10sdp"
                android:paddingTop="@dimen/_10sdp"
                android:text="Enter Email"
                android:textColor="@color/black"
                android:textSize="@dimen/_12sdp" />

            <androidx.appcompat.widget.AppCompatEditText
                android:visibility="gone"
                android:id="@+id/SignUpEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:autofillHints="@string/email_address"
                android:background="@drawable/box_frame_offwhite"
                android:fontFamily="@font/kohsantepheap_regular"
                android:hint="@string/email_address"
                android:inputType="textEmailAddress"
                android:paddingStart="10dp"
                android:paddingEnd="5dp"
                android:imeOptions="actionNext"
                android:textAppearance="@style/customTextTheme"
                android:textColor="@color/black"
                android:textColorHint="@color/hintcolor"
                android:textSize="15sp"
                tools:ignore="RtlSymmetry" />



            <androidx.appcompat.widget.AppCompatEditText
                android:drawablePadding="@dimen/_7sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:id="@+id/SignUpPhone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:autofillHints="@string/phone_number"
                android:background="@drawable/box_frame_offwhite"
                android:fontFamily="@font/poppins_semibold"
                android:hint="@string/phone_number"
                android:inputType="number"
                android:maxLength="10"
                android:paddingStart="10dp"
                android:paddingEnd="5dp"
                android:textAppearance="@style/customTextTheme"
                android:textColor="@color/black"
                android:imeOptions="actionNext"
                android:textColorHint="@color/hintcolor"
                android:textSize="15sp"
                tools:ignore="RtlSymmetry" />



            <com.scottyab.showhidepasswordedittext.ShowHidePasswordEditText
                android:id="@+id/SignUpPassword"
                android:drawablePadding="@dimen/_7sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:autofillHints="@string/password"
                android:background="@drawable/box_frame_offwhite"
                android:fontFamily="@font/poppins_semibold"
                android:hint="@string/password"
                android:inputType="text"
                android:paddingStart="10dp"
                android:imeOptions="actionDone"
                android:paddingEnd="5dp"
                android:textAppearance="@style/customTextTheme"
                android:textColor="@color/black"
                android:textColorHint="@color/hintcolor"
                android:textSize="15sp"
                app:additionalTouchTargetSize="50dp"
                tools:ignore="RtlSymmetry" />

            <com.scottyab.showhidepasswordedittext.ShowHidePasswordEditText
                android:id="@+id/SignUpmPin"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="20dp"
                android:autofillHints="@string/mPin"
                android:background="@drawable/box_frame_offwhite"
                android:elevation="0dp"
                android:fontFamily="@font/poppins_semibold"
                android:hint="@string/mPin"
                android:inputType="numberPassword"
                android:imeOptions="actionDone"
                android:maxLength="4"
                android:paddingStart="10dp"
                android:paddingEnd="5dp"
                android:textAppearance="@style/customTextTheme"
                android:textColor="@color/white"
                android:textColorHint="@color/hintcolor"
                android:textSize="15sp"
                app:additionalTouchTargetSize="50dp"
                tools:ignore="RtlSymmetry" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/SignUpBT"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="@dimen/_20sdp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/primary_button_design"
                android:elevation="0dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/sign_up"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_20sdp"
                android:id="@+id/loginSignUpTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_light"
                android:text="@string/already_registered"
                android:textColor="@color/black"
                android:alpha="0.8"
                android:textSize="@dimen/_13sdp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-38dp"
                android:text="@string/contact_us"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

           



        </LinearLayout>

        <RelativeLayout
            android:layout_gravity="center"
            android:gravity="center"
            android:id="@+id/progressbar2"
            android:translationZ="10dp"
            android:visibility="gone"
            android:layout_centerInParent="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <include layout="@layout/custom_progress_bar"/>
        </RelativeLayout>

        <ImageView
            android:padding="@dimen/_10ssp"
            android:layout_margin="@dimen/_10ssp"
            android:layout_alignParentEnd="true"
            android:visibility="visible"
            android:id="@+id/signup_whatappbut"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="@dimen/_60sdp"
            android:layout_alignParentBottom="true"
            android:src="@drawable/ic_whatsapp" />


        <ImageView
            android:visibility="gone"
            android:id="@+id/signup_callbut"
            android:src="@drawable/ic_call_new"
            android:layout_alignParentEnd="true"
            android:layout_margin="10dp"
            android:layout_alignParentBottom="true"
            android:layout_width="56dp"
            android:layout_height="56dp"/>

    </RelativeLayout>

</androidx.core.widget.NestedScrollView>